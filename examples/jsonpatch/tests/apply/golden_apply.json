{
  "cases": [
    {
      "desc": "add object member",
      "doc": "{\"a\": 1}",
      "patch": "[{\"op\": \"add\", \"path\": \"/b\", \"value\": 2}]",
      "ok": true,
      "result": {
        "a": 1,
        "b": 2
      }
    },
    {
      "desc": "add nested",
      "doc": "{\"a\": {}}",
      "patch": "[{\"op\": \"add\", \"path\": \"/a/x\", \"value\": [1, 2]}]",
      "ok": true,
      "result": {
        "a": {
          "x": [
            1,
            2
          ]
        }
      }
    },
    {
      "desc": "add array index",
      "doc": "{\"a\": [1, 3]}",
      "patch": "[{\"op\": \"add\", \"path\": \"/a/1\", \"value\": 2}]",
      "ok": true,
      "result": {
        "a": [
          1,
          2,
          3
        ]
      }
    },
    {
      "desc": "add array append -",
      "doc": "{\"a\": [1, 2]}",
      "patch": "[{\"op\": \"add\", \"path\": \"/a/-\", \"value\": 3}]",
      "ok": true,
      "result": {
        "a": [
          1,
          2,
          3
        ]
      }
    },
    {
      "desc": "remove member",
      "doc": "{\"a\": 1, \"b\": 2}",
      "patch": "[{\"op\": \"remove\", \"path\": \"/b\"}]",
      "ok": true,
      "result": {
        "a": 1
      }
    },
    {
      "desc": "remove array elem",
      "doc": "{\"a\": [1, 2, 3]}",
      "patch": "[{\"op\": \"remove\", \"path\": \"/a/1\"}]",
      "ok": true,
      "result": {
        "a": [
          1,
          3
        ]
      }
    },
    {
      "desc": "replace",
      "doc": "{\"a\": 1}",
      "patch": "[{\"op\": \"replace\", \"path\": \"/a\", \"value\": 9}]",
      "ok": true,
      "result": {
        "a": 9
      }
    },
    {
      "desc": "move",
      "doc": "{\"a\": {\"x\": 1}, \"b\": {}}",
      "patch": "[{\"op\": \"move\", \"from\": \"/a/x\", \"path\": \"/b/y\"}]",
      "ok": true,
      "result": {
        "a": {},
        "b": {
          "y": 1
        }
      }
    },
    {
      "desc": "copy",
      "doc": "{\"a\": 1}",
      "patch": "[{\"op\": \"copy\", \"from\": \"/a\", \"path\": \"/c\"}]",
      "ok": true,
      "result": {
        "a": 1,
        "c": 1
      }
    },
    {
      "desc": "test ok",
      "doc": "{\"a\": 1}",
      "patch": "[{\"op\": \"test\", \"path\": \"/a\", \"value\": 1}]",
      "ok": true,
      "result": {
        "a": 1
      }
    },
    {
      "desc": "test fail",
      "doc": "{\"a\": 1}",
      "patch": "[{\"op\": \"test\", \"path\": \"/a\", \"value\": 2}]",
      "ok": false,
      "error": "TestFailed"
    },
    {
      "desc": "pointer escape ~1 (slash)",
      "doc": "{\"a/b\": 1}",
      "patch": "[{\"op\": \"replace\", \"path\": \"/a~1b\", \"value\": 2}]",
      "ok": true,
      "result": {
        "a/b": 2
      }
    },
    {
      "desc": "pointer escape ~0 (tilde)",
      "doc": "{\"a~b\": 1}",
      "patch": "[{\"op\": \"replace\", \"path\": \"/a~0b\", \"value\": 2}]",
      "ok": true,
      "result": {
        "a~b": 2
      }
    },
    {
      "desc": "multi-op sequence",
      "doc": "{\"a\": 1}",
      "patch": "[{\"op\": \"add\", \"path\": \"/b\", \"value\": 2}, {\"op\": \"remove\", \"path\": \"/a\"}]",
      "ok": true,
      "result": {
        "b": 2
      }
    },
    {
      "desc": "replace root",
      "doc": "{\"a\": 1}",
      "patch": "[{\"op\": \"replace\", \"path\": \"\", \"value\": {\"z\": 9}}]",
      "ok": true,
      "result": {
        "z": 9
      }
    },
    {
      "desc": "add to missing parent (conflict)",
      "doc": "{\"a\": 1}",
      "patch": "[{\"op\": \"add\", \"path\": \"/x/y\", \"value\": 1}]",
      "ok": false,
      "error": "InvalidPointer"
    },
    {
      "desc": "remove missing (conflict)",
      "doc": "{\"a\": 1}",
      "patch": "[{\"op\": \"remove\", \"path\": \"/nope\"}]",
      "ok": false,
      "error": "Conflict"
    },
    {
      "desc": "replace missing (conflict)",
      "doc": "{\"a\": 1}",
      "patch": "[{\"op\": \"replace\", \"path\": \"/nope\", \"value\": 1}]",
      "ok": false,
      "error": "Conflict"
    },
    {
      "desc": "test missing path (conflict)",
      "doc": "{\"a\": 1}",
      "patch": "[{\"op\": \"test\", \"path\": \"/nope\", \"value\": 1}]",
      "ok": false,
      "error": "TestFailed"
    },
    {
      "desc": "array index out of range",
      "doc": "{\"a\": [1]}",
      "patch": "[{\"op\": \"add\", \"path\": \"/a/5\", \"value\": 9}]",
      "ok": false,
      "error": "Conflict"
    },
    {
      "desc": "move into own child (conflict?)",
      "doc": "{\"a\": {\"b\": {}}}",
      "patch": "[{\"op\": \"move\", \"from\": \"/a\", \"path\": \"/a/b/c\"}]",
      "ok": false,
      "error": "Conflict"
    },
    {
      "desc": "copy array elem",
      "doc": "{\"a\": [1, 2]}",
      "patch": "[{\"op\": \"copy\", \"from\": \"/a/0\", \"path\": \"/a/-\"}]",
      "ok": true,
      "result": {
        "a": [
          1,
          2,
          1
        ]
      }
    },
    {
      "desc": "empty patch",
      "doc": "{\"a\": 1}",
      "patch": "[]",
      "ok": true,
      "result": {
        "a": 1
      }
    },
    {
      "desc": "number/bool/null values",
      "doc": "{}",
      "patch": "[{\"op\": \"add\", \"path\": \"/n\", \"value\": null}, {\"op\": \"add\", \"path\": \"/b\", \"value\": true}]",
      "ok": true,
      "result": {
        "n": null,
        "b": true
      }
    },
    {
      "desc": "unknown op (invalid)",
      "doc": "{\"a\": 1}",
      "patch": "[{\"op\": \"frobnicate\", \"path\": \"/a\"}]",
      "ok": false,
      "error": "InvalidPatch"
    }
  ]
}
